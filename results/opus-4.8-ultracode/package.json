{
  "name": "splash-critters",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch packages/server/src/index.ts",
    "dev:client": "vite --config packages/client/vite.config.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config packages/client/vite.config.ts",
    "build:server": "node scripts/build-server.mjs",
    "start": "node packages/server/dist/index.js",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "soak": "tsx packages/server/src/soak.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.0",
    "express": "^4.19.0",
    "ws": "^8.18.0"
  }
}
